{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx packages/core/src/dev.ts",
    "demo": "tsx packages/core/src/dev.ts",
    "compose:replay": "pnpm --filter @forge/compose compose:replay",
    "evals:replay": "pnpm --filter @forge/evals evals:replay",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  }
}
